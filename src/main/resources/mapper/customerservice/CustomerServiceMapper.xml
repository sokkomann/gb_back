<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.app.bideo.mapper.customerservice.CustomerServiceMapper">

    <insert id="insertInquiry" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tbl_inquiry (member_id, category, content, status)
        VALUES (#{memberId}, #{category}, #{content}, 'PENDING')
    </insert>

</mapper>
